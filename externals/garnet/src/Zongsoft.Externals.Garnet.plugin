<?xml version="1.0" encoding="utf-8" ?>

<plugin name="Zongsoft.Externals.Garnet"
        title="Zongsoft.Externals.Garnet Plugin"
        author="Zongsoft Studio(zongsoft@qq.com)"
        copyright="Copyright(C) Zongsoft Studio. 2020-2026. All rights reserved."
        description="Created Date: 2026-05-10 by Popeye Zhong" >

	<manifest>
		<assemblies>
			<assembly name="Zongsoft.Externals.Garnet" />
		</assemblies>
	</manifest>

	<extension path="/Workbench/Startup">
		<object name="GarnetServer" setting="default" type="Zongsoft.Externals.Garnet.GarnetServer, Zongsoft.Externals.Garnet" />
	</extension>
</plugin>